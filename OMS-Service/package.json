{
  "name": "node-express-mongoose-boilerplate",
  "version": "1.5.0",
  "description": "A boilerplate for building production-ready RESTful APIs using Node.js, Express, and Mongoose",
  "main": "src/index.js",
  "repository": "https://github.com/hagopj13/node-express-mongoose-boilerplate.git",
  "author": "Styli Engineering",
  "license": "MIT",
  "engines": {
    "node": ">=12.0.0"
  },
  "scripts": {
    "start": "pm2-runtime start ecosystem.config.json",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js --exec 'yarn lint && node'",
    "dev:disbale-lint": "cross-env NODE_ENV=development nodemon src/index.js --exec",
    "dev:uat": "cross-env NODE_ENV=uat nodemon src/index.js --exec 'yarn lint && node'",
    "dev:qa": "cross-env NODE_ENV=qa nodemon src/index.js --exec 'yarn lint && node'",
    "dev:debug": "cross-env NODE_ENV=development nodemon --inspect-brk=9229 src/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest -i --watchAll",
    "coverage": "jest -i --coverage",
    "coverage:coveralls": "jest -i --coverage --coverageReporters=text-lcov | coveralls",
    "eslint": "node_modules/eslint/bin/eslint.js --init",
    "lint": "node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node_modules/eslint/bin/eslint.js . --fix",
    "prettier": "prettier --check **/*.js",
    "prettier:fix": "prettier --write **/*.js",
    "prettier:fix1": "prettier --write **/**/*.js",
    "prettier:fix2": "prettier --write **/**/**/*.js",
    "prettier:fix3": "prettier --write **/**/**/**/*.js",
    "prettier:fix4": "prettier --write **/**/**/**/**/*.js",
    "prettier:fix6": "prettier --write src/**/**/**/**/**/**/**/*.js",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:test": "docker-compose -f docker-compose.yml -f docker-compose.test.yml up",
    "precommit": "lint-staged && prettier:fix6"
  },
  "keywords": [
    "node",
    "node.js",
    "boilerplate",
    "generator",
    "express",
    "rest",
    "api",
    "mongodb",
    "mongoose",
    "es6",
    "es7",
    "es8",
    "es9",
    "jest",
    "travis",
    "docker",
    "passport",
    "joi",
    "eslint",
    "prettier"
  ],
