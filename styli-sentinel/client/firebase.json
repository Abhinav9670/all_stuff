{
  "hosting": [
    {
      "target": "dev",
      "public": "build",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=0, no-cache"
            }
          ]
        },
        {
          "source": "**/*.@(js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=3600000000"
            }
          ]
        }
      ],
      "redirects": [
        {
          "source": "/",
          "destination": "https://stylisentinel-dev.stylifashion.com/user/login",
          "type": 301
        }
      ]
    },
    {
      "target": "production",
      "public": "build",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=0, no-cache"
            }
          ]
        },
        {
          "source": "**/*.(js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=3600000000"
            }
          ]
        }
      ],
      "redirects": [
        {
          "source": "/",
          "destination": "https://stylisentinel.stylishop.store/user/login",
          "type": 301
        }
      ]
    }
  ]
}
