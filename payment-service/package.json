{
  "name": "styli-payment-service",
  "version": "1.2.2",
  "description": "Payment Micro service for STYLI",
  "author": "Nishant Gupta",
  "main": "src/index.js",
  "private": false,
  "license": "MIT",
  "engines": {
    "node": ">=8",
    "yarn": "*"
  },
  "scripts": {
    "precommit": "yarn lint",
    "prestart": "yarn docs",
    "start": "pm2-runtime start ecosystem.config.json",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js --exec 'yarn lint && node'",
    "lint": "node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node_modules/eslint/bin/eslint.js . --fix",
    "lint:watch": "yarn lint --watch",
    "test": "jest",
    "unit": "cross-env NODE_ENV=test jest",
    "test:integration": "cross-env NODE_ENV=test mocha --timeout 20000 --exit src/api/tests/integration",
    "test:watch": "cross-env NODE_ENV=test mocha --watch src/api/tests/unit",
    "coverage": "nyc report --reporter=text-lcov | coveralls",
    "postcoverage": "open-cli coverage/lcov-report/index.html",
    "validate": "yarn lint && yarn test",
    "postpublish": "git push --tags",
    "deploy": "sh ./deploy.sh",
    "docs": "apidoc -i src -o docs",
    "postdocs": "open-cli docs/index.html",
    "docker:start": "cross-env NODE_ENV=production pm2-docker start ./src/index.js",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:test": "docker-compose -f docker-compose.yml -f docker-compose.test.yml up --abort-on-container-exit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Styli-dev/payment-service.git"
  },
  "keywords": [
    "express",
    "node"
  ],
  "dependencies": {
    "axios": "1.7.2",
    "bcryptjs": "2.4.3",
    "bluebird": "^3.5.0",
    "body-parser": "^1.17.0",
    "cls-hooked": "4.2.2",
    "compression": "^1.6.2",
    "consul": "^0.40.0",
    "cors": "^2.8.3",
    "couchbase": "^4.1.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.1",
    "elastic-apm-node": "4.11.0",
    "email-templates": "12.0.1",
    "express": "4.19.2",
    "express-validation": "^1.0.2",
    "find-config": "^1.0.0",
    "helmet": "^4.6.0",
    "http-status": "^1.0.1",
    "ioredis": "^5.2.3",
    "jest": "^29.5.0",
    "jest-html-reporters": "^3.1.4",
    "jest-xunit": "^1.0.11",
    "joi": "^10.4.1",
    "jsonwebtoken": "9.0.0",
    "jwt-decode": "^3.1.2",
    "jwt-simple": "0.5.6",
    "lodash": "4.17.21",
    "memory-cache": "^0.2.0",
    "method-override": "^3.0.0",
    "moment-timezone": "^0.5.13",
    "mongodb": "^3.6.4",
    "mongoose": "6.11.5",
    "morgan": "^1.8.1",
    "mysql2-promise": "^0.1.4",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.3.1",
    "passport": "^0.6.0",
    "passport-http-bearer": "^1.0.1",
    "passport-jwt": "4.0.0",
    "pm2": "^5.1.0",
    "pug": "^3.0.1",
    "serialize-error": "8.0.1",
    "sinon": "18.0.0",
    "sinon-chai": "4.0.0",
    "uuid": "^3.1.0",
    "winston": "^3.1.0"
  },
  "resolutions": {
    "lodash": "4.17.21"
  },
  "devDependencies": {
    "apidoc": "^0.28.1",
    "chai": "^4.1.0",
    "chai-as-promised": "^7.1.1",
    "coveralls": "^3.0.0",
    "eslint": "^7.29.0",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-config-styli": "^0.0.5",
    "eslint-plugin-import": "^2.2.0",
    "husky": "^3.0.7",
    "mocha": "^6.2.2",
    "nodemon": "^2.0.1",
    "nyc": "^15.1.0",
    "opn-cli": "^5.0.0",
    "supertest": "^6.3.3"
  }
}
