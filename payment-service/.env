PORT=5001
NODE_ENV=${node_env}

### My SQL Connection ###
MYSQL_HOST=${mysql_host}
MYSQL_USER=${mysql_user}
MYSQL_PWD=${mysql_pwd}
MYSQL_DB=${mysql_db}

### Couchbase ###
COUCHBASE_CLUSTER_ADDRESS=${cb_address}
COUCHBASE_CLUSTER_USERNAME=${cb_user}
COUCHBASE_CLUSTER_PASSWORD=${cb_pass}
COUCHBASE_CLUSTER_BUCKET=customer

##### Consul Config ######
CONSUL_HOST=${consul_host}
CONSUL_PORT=${consul_port}
CONSUL_TOKEN=${consul_token}
CONSUL_PAYMENT_METHODS=${consul_payment_methods}


##### Apple Pay #####
MERCHANT_KEY_PATH=./src/certs/merchant_id.key.pem
MERCHANT_CERT_PATH=./src/certs/merchant_id.crt.pem

REDIS_HOST=${redis_host}
REDIS_PORT=${redis_port}
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_AUTH_KEY=${redis_authkey}
AUTH_INTERNAL_HEADER_BEARER_TOKEN=${AUTH_INTERNAL_HEADER_BEARER_TOKEN}